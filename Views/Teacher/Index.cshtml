@model List<SchoolProject.Models.Teacher>

@{
    ViewData["Title"] = "Teachers";
}

<div class="data-card">
    <div class="card-header">
        <h5><i class="bi bi-person-workspace text-success"></i> All Teachers</h5>
        <a asp-action="Create" class="btn btn-success-custom btn-sm">
            <i class="bi bi-plus-lg"></i> Add Teacher
        </a>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Age</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">
                        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                        <p class="mt-2">No teachers yet. Add your first teacher!</p>
                    </td>
                </tr>
            }
            @foreach (var teacher in Model)
            {
                <tr>
                    <td>@teacher.TeacherId</td>
                    <td><strong>@teacher.TeacherName</strong></td>
                    <td>@teacher.TeacherAge</td>
                    <td>
                        <form asp-action="Delete" asp-route-id="@teacher.TeacherId" method="post" style="display:inline;">
                            <button type="submit" class="btn btn-danger-custom" onclick="return confirm('Are you sure you want to delete this teacher?')">
                                <i class="bi bi-trash3"></i> Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
