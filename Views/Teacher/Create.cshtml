@model SchoolProject.Models.Teacher

@{
    ViewData["Title"] = "Add Teacher";
}

<div class="form-card">
    <h5 class="mb-4"><i class="bi bi-person-plus-fill text-success"></i> Add New Teacher</h5>
    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="TeacherName" class="form-label">Teacher Name</label>
            <input asp-for="TeacherName" class="form-control" placeholder="Enter teacher name" />
            <span asp-validation-for="TeacherName" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="TeacherAge" class="form-label">Age</label>
            <input asp-for="TeacherAge" class="form-control" type="number" placeholder="Enter age" />
            <span asp-validation-for="TeacherAge" class="text-danger"></span>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success-custom"><i class="bi bi-check-lg"></i> Save</button>
            <a asp-action="Index" class="btn btn-secondary-custom"><i class="bi bi-arrow-left"></i> Back</a>
        </div>
    </form>
</div>
