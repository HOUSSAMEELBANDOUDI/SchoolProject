@model List<SchoolProject.Models.Room>

@{
    ViewData["Title"] = "Rooms";
}

<div class="data-card">
    <div class="card-header">
        <h5><i class="bi bi-door-open-fill" style="color: #9333ea;"></i> All Rooms</h5>
        <a asp-action="Create" class="btn btn-primary-custom btn-sm" style="background-color: #9333ea;">
            <i class="bi bi-plus-lg"></i> Add Room
        </a>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Room Name</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="3" class="text-center text-muted py-4">
                        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                        <p class="mt-2">No rooms yet. Add your first room!</p>
                    </td>
                </tr>
            }
            @foreach (var room in Model)
            {
                <tr>
                    <td>@room.RoomId</td>
                    <td><strong>@room.RoomName</strong></td>
                    <td>
                        <form asp-action="Delete" asp-route-id="@room.RoomId" method="post" style="display:inline;">
                            <button type="submit" class="btn btn-danger-custom" onclick="return confirm('Are you sure you want to delete this room?')">
                                <i class="bi bi-trash3"></i> Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
