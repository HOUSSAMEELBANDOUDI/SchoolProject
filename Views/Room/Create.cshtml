@model SchoolProject.Models.Room

@{
    ViewData["Title"] = "Add Room";
}

<div class="form-card">
    <h5 class="mb-4"><i class="bi bi-door-open-fill" style="color: #9333ea;"></i> Add New Room</h5>
    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="RoomName" class="form-label">Room Name</label>
            <input asp-for="RoomName" class="form-control" placeholder="Enter room name" />
            <span asp-validation-for="RoomName" class="text-danger"></span>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary-custom" style="background-color: #9333ea;"><i class="bi bi-check-lg"></i> Save</button>
            <a asp-action="Index" class="btn btn-secondary-custom"><i class="bi bi-arrow-left"></i> Back</a>
        </div>
    </form>
</div>
