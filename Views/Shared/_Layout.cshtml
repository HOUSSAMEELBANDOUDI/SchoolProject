<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - School System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-wrapper">
        <!-- SIDEBAR -->
        <aside class="sidebar">
            <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-mortarboard-fill"></i> School System
            </a>
            <ul class="sidebar-nav">
                <li class="nav-label">Main</li>
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                        <span class="nav-icon"><i class="bi bi-grid-1x2-fill"></i></span> Dashboard
                    </a>
                </li>

                <li class="nav-label">Management</li>
                <li class="nav-item">
                    <a asp-controller="Student" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Student" ? "active" : "")">
                        <span class="nav-icon"><i class="bi bi-people-fill"></i></span> Students
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Teacher" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Teacher" ? "active" : "")">
                        <span class="nav-icon"><i class="bi bi-person-workspace"></i></span> Teachers
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Room" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Room" ? "active" : "")">
                        <span class="nav-icon"><i class="bi bi-door-open-fill"></i></span> Rooms
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Course" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Course" ? "active" : "")">
                        <span class="nav-icon"><i class="bi bi-book-fill"></i></span> Courses
                    </a>
                </li>

                <li class="nav-label">Actions</li>
                <li class="nav-item">
                    <a asp-controller="Student" asp-action="Register"
                       class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Register" ? "active" : "")">
                        <span class="nav-icon"><i class="bi bi-person-plus-fill"></i></span> Register Student
                    </a>
                </li>
            </ul>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="main-content">
            <div class="top-bar">
                <h4>@ViewData["Title"]</h4>
                <span class="text-muted" style="font-size: 0.85rem;">
                    <i class="bi bi-calendar3"></i> @DateTime.Now.ToString("dddd, MMMM dd, yyyy")
                </span>
            </div>
            <div class="content-area">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
