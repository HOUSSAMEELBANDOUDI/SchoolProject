@{
    ViewData["Title"] = "Register Student in Course";
}

<div class="form-card">
    <h5 class="mb-4"><i class="bi bi-person-check-fill text-success"></i> Register Student in Course</h5>
    <form asp-action="Register" method="post">
        <div class="mb-3">
            <label class="form-label">Select Student</label>
            <select name="studentId" class="form-control" asp-items="@ViewBag.Students">
                <option value="">-- Select Student --</option>
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Select Course</label>
            <select name="courseId" class="form-control" asp-items="@ViewBag.Courses">
                <option value="">-- Select Course --</option>
            </select>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success-custom"><i class="bi bi-check-lg"></i> Register</button>
            <a asp-controller="Student" asp-action="Index" class="btn btn-secondary-custom"><i class="bi bi-arrow-left"></i> Back</a>
        </div>
    </form>
</div>
