@model SchoolProject.Models.Course

@{
    ViewData["Title"] = "Add Course";
}

<div class="form-card">
    <h5 class="mb-4"><i class="bi bi-book-fill" style="color: #ea580c;"></i> Add New Course</h5>
    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="CourseName" class="form-label">Course Name</label>
            <input asp-for="CourseName" class="form-control" placeholder="Enter course name" />
            <span asp-validation-for="CourseName" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="CourseCapacity" class="form-label">Capacity</label>
            <input asp-for="CourseCapacity" class="form-control" type="number" placeholder="Enter max capacity (0-25)" />
            <span asp-validation-for="CourseCapacity" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="TeacherId" class="form-label">Teacher</label>
            <select asp-for="TeacherId" class="form-control" asp-items="@ViewBag.Teachers">
                <option value="">-- Select Teacher --</option>
            </select>
            <span asp-validation-for="TeacherId" class="text-danger"></span>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary-custom" style="background-color: #ea580c;"><i class="bi bi-check-lg"></i> Save</button>
            <a asp-action="Index" class="btn btn-secondary-custom"><i class="bi bi-arrow-left"></i> Back</a>
        </div>
    </form>
</div>
