@model List<SchoolProject.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<h2>Courses</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Add New Course</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Course Name</th>
            <th>Capacity</th>
            <th>Teacher</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var course in Model)
        {
            <tr>
                <td>@course.CourseId</td>
                <td>@course.CourseName</td>
                <td>@course.CourseCapacity</td>
                <td>@(course.Teacher != null ? course.Teacher.TeacherName : "N/A")</td>
                <td>
                    <form asp-action="Delete" asp-route-id="@course.CourseId" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure?')">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
